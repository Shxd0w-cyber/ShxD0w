-- Helper Function to Render Toggles Beautifully
local function CreateFeatureToggle(name, callback)
    local Button = Instance.new("TextButton")
    Button.Size = UDim2.new(1, -5, 0, 45)
    Button.BackgroundColor3 = Color3.fromRGB(45, 45, 55)
    Button.Text = name .. " : OFF"
    Button.TextColor3 = Color3.fromRGB(220, 70, 70)
    Button.Font = Enum.Font.SourceSansSemibold
    Button.TextSize = 16
    Button.Parent = ScrollingFrame
    
    local BCorner = Instance.new("UICorner")
    BCorner.CornerRadius = UDim.new(0, 6)
    BCorner.Parent = Button
    
    local active = false
    Button.MouseButton1Click:Connect(function()
        active = not active
        if active then
            Button.Text = name .. " : ON"
            Button.TextColor3 = Color3.fromRGB(70, 220, 70)
            Button.BackgroundColor3 = Color3.fromRGB(55, 65, 55)
        else
            Button.Text = name .. " : OFF"
            Button.TextColor3 = Color3.fromRGB(220, 70, 70)
            Button.BackgroundColor3 = Color3.fromRGB(45, 45, 55)
        end
        callback(active)
    end)
end

