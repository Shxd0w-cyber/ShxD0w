-- Safe Framework Hooks
local function getControllerSafely(name)
    local success, Knit = pcall(function() return require(ReplicatedStorage:WaitForChild("Packages"):WaitForChild("Knit")) end)
    if success and Knit then
        local res, controller = pcall(function() return Knit.GetController(name) end)
        if res then return controller end
    end
    return nil
end

