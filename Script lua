local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")

-- Configuration
local TACKLE_DISTANCE = 6 -- Adjust based on game physics

-- YOUR MATCHING LOGIC: Helper function to validate if the football has a unique game ID (UUID)
local function isUUID(str)
    if #str ~= 36 then return false end
    local hyphenCount = 0
    for i = 1, #str do
        local c = str:sub(i,i)
        if c == "-" then 
            hyphenCount = hyphenCount + 1 
        elseif not (c:match("%x") or c == "-") then 
            return false 
        end
    end
    return hyphenCount == 4
end

-- YOUR SCANNING LOGIC: Finds the precise ball object currently spawned in the server
local function findRealFootball()
    local bestCandidate = nil
    local bestScore = 0 
    
    for _, obj in ipairs(workspace:GetDescendants()) do 
        if obj.Name:match("^Football") then 
            local suffix = obj.Name:sub(9)
            local noSpaceSuffix = suffix:gsub("%s+", "") 
            local score = 0 
            local partCount = 0 
            
            for _, part in ipairs(obj:GetDescendants()) do 
                if part:IsA("BasePart") and part.CanCollide then 
                    partCount = partCount + 1 
                end 
            end 
            
            if obj:IsA("Model") then score = score + 3 end 
            score = score + partCount * 2 
            
            if isUUID(suffix) or isUUID(noSpaceSuffix) then 
                score = score + 10 
            end 
            
            if score > bestScore then 
                bestScore = score 
                bestCandidate = obj 
            end 
        end 
    end 
    return bestCandidate 
end

-- NEW CHECKER: Finds which opposing player is holding or closest to the real ball
local function getBallCarrier()
    local targetBall = findRealFootball()
    if not targetBall then return nil, math.huge end

    local closestCarrier = nil
    local shortestDistance = math.huge
    
    for _, player in ipairs(Players:GetPlayers()) do
        -- Skip yourself, and make sure the other player is alive/spawned
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            
            -- Method A: Is the dynamically named ball cloned directly inside their character model?
            local holdingBall = player.Character:FindFirstChild(targetBall.Name)
            
            -- Method B: Is it inside their backpack?
            local hasBallInBackpack = player.Backpack:FindFirstChild(targetBall.Name)
            
            -- Method C (Proximity): Is the ball physically touching/welded to them?
            local isPhysicallyClose = false
            local ballPrimary = targetBall:IsA("Model") and targetBall.PrimaryPart or targetBall:FindFirstChildWhichIsA("BasePart")
            if ballPrimary then
                local ballDist = (player.Character.HumanoidRootPart.Position - ballPrimary.Position).Magnitude
                if ballDist < 3 then -- If they are within 3 studs of the ball, they are carrying it
                    isPhysicallyClose = true
                end
            end
            
            -- If any carrier condition is met, evaluate them as the target
            if holdingBall or hasBallInBackpack or isPhysicallyClose then
                local playerDistance = (LocalPlayer.Character.HumanoidRootPart.Position - player.Character.HumanoidRootPart.Position).Magnitude
                
                if playerDistance < shortestDistance then
                    shortestDistance = playerDistance
                    closestCarrier = player
                end
            end
        end
    end
    return closestCarrier, shortestDistance
end

-- Continuous tracking loop
RunService.Heartbeat:Connect(function()
    if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then return end
    
    local targetPlayer, distance = getBallCarrier()
    
    -- Only act if a valid target with the ball is found within range
    if targetPlayer and distance <= TACKLE_DISTANCE then
        print("Tackling ball carrier: " .. targetPlayer.Name .. " | Distance: " .. tostring(math.floor(distance)))
        
        -- INSERT TACKLE ACTION HERE
        -- Example: game:GetService("ReplicatedStorage").Remotes.Tackle:FireServer()
    end
end)
